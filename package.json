{
  "name": "korean-government-api-bundle",
  "version": "0.1.0",
  "private": false,
  "description": "Question-first MCP + CLI bundle for Korean government public APIs",
  "type": "module",
  "bin": {
    "kgab": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/cli/index.js",
    "mcp": "npm run build && node dist/mcp/server.js --list-tools",
    "lint": "tsc -p tsconfig.json --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
